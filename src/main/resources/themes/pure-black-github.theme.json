{
  "name": "GitHub Dark Pure Black",
  "dark": true,
  "author": "vedhavyas",
  "parentTheme": "Islands Dark",
  "editorScheme": "/colors/github-dark-pure-black.xml",

  "colors": {
    "layer-0-bg":        "#000000",
    "layer-0-bg-inline": "#000000",
    "layer-1-bg":        "#000000",
    "layer-1-bg-inline": "#000000",
    "layer-2-bg":        "#000000",
    "layer-2-bg-inline": "#000000",

    "layer-0-border":        "#30363d",
    "layer-0-border-inline": "#30363d",
    "layer-1-border":        "#30363d",
    "layer-1-border-inline": "#30363d",
    "layer-2-border":        "#30363d",
    "layer-2-border-inline": "#30363d"
  },

  "ui": {
    "*": {
      "background":          "#000000",
      "disabledBackground":  "#000000",
      "inactiveBackground":  "#000000",
      "selectionBackground": "#264F78",
      "selectionForeground": "#FFFFFF",
      "foreground":          "#e6edf3",
      "disabledText":        "#6A737D",
      "infoForeground":      "#8b949e",
      "separatorColor":      "#30363d",
      "borderColor":         "#30363d"
    },

    "ToolWindow":              { "background": "#000000" },
    "Tree":                    { "background": "#000000" },
    "List":                    { "background": "#000000" },
    "Table":                   { "background": "#000000" },
    "EditorPane":              { "background": "#000000", "inactiveBackground": "#000000" },
    "EditorTabs":              { "background": "#000000", "underlinedTabBackground": "#000000", "inactiveUnderlinedTabBackground": "#000000", "borderColor": "#30363d" },
    "Editor":                  { "background": "#000000", "border": "#30363d" },
    "MainWindow":              { "background": "#000000", "separatorColor": "#30363d", "Tab": { "background": "#000000", "selectedBackground": "#000000" } },
    "StatusBar":               { "background": "#000000", "borderColor": "#30363d" },
    "Panel":                   { "background": "#000000" },
    "SidePanel":               { "background": "#000000" },
    "TabbedPane":              { "background": "#000000" },
    "ToolBar":                 { "background": "#000000", "borderHandleColor": "#30363d" },
    "Viewport":                { "background": "#000000" },
    "ScrollPane":              { "background": "#000000" },
    "PopupMenu":               { "background": "#000000", "borderColor": "#30363d" },
    "Menu":                    { "background": "#000000", "borderColor": "#30363d" },
    "MenuBar":                 { "background": "#000000", "borderColor": "#30363d" },
    "MenuItem":                { "background": "#000000" },
    "AlertDialog":             { "background": "#000000" },
    "ComplexPopup":            { "background": "#000000", "Header": { "background": "#000000" } },
    "NotificationsToolwindow": { "background": "#000000", "newNotification": { "background": "#000000" }, "Notification": { "background": "#000000" } },
    "NewUiOnboarding":         { "Dialog": { "background": "#000000" } },
    "ConsoleView":             { "background": "#000000" },
    "TerminalConsole":         { "background": "#000000" },
    "Terminal":                { "background": "#000000" },
    "TextArea":                { "background": "#000000", "inactiveBackground": "#000000" },
    "TextField":               { "background": "#000000", "inactiveBackground": "#000000" },
    "PasswordField":           { "background": "#000000" },
    "FormattedTextField":      { "background": "#000000" },
    "ComboBox":                { "background": "#000000", "nonEditableBackground": "#000000" },
    "ComboPopup":              { "background": "#000000" },
    "CheckBox":                { "background": "#000000" },
    "RadioButton":             { "background": "#000000" },
    "Button":                  { "background": "#000000", "startBackground": "#000000", "endBackground": "#000000" },
    "ActionButton":            { "background": "#000000" },
    "ServiceView":             { "background": "#000000" },
    "Bookmark":                { "background": "#000000" },

    "OnePixelDivider":         { "background": "#30363d" },
    "Borders":                 { "color": "#30363d" },
    "Component":               { "borderColor": "#30363d", "focusColor": "#58a6ff" }
  }
}
